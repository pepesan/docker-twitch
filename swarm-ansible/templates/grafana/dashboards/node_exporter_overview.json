  "panels": [
    {
      "title": "Host CPU Utilization",
      "type": "gauge",
      "id": 1,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "(1 - avg(rate(node_cpu_seconds_total{instance=~\"$instance:9100\", mode=\"idle\"}[1m]))) * 100",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        }
      }
    },
    {
      "title": "Host Memory Utilization",
      "type": "gauge",
      "id": 2,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{instance=~\"$instance:9100\"} / node_memory_MemTotal_bytes{instance=~\"$instance:9100\"}) * 100",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      }
    },
    {
      "title": "Host Disk Space Usage",
      "type": "gauge",
      "id": 3,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "(1 - node_filesystem_free_bytes{instance=~\"$instance:9100\", mountpoint=\"/\"} / node_filesystem_size_bytes{instance=~\"$instance:9100\", mountpoint=\"/\"}) * 100",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      }
    },
    {
      "title": "System Load (1m / 5m / 15m)",
      "type": "stat",
      "id": 4,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "node_load1{instance=~\"$instance:9100\"}",
          "legendFormat": "Load 1m",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "node_load5{instance=~\"$instance:9100\"}",
          "legendFormat": "Load 5m",
          "refId": "B",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value"
      }
    },
    {
      "title": "Host CPU Utilization Detail",
      "type": "timeseries",
      "id": 5,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(node_cpu_seconds_total{instance=~\"$instance:9100\", mode!=\"idle\"}[1m])) by (mode) * 100",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "percent"
        }
      }
    },
    {
      "title": "System Load Over Time",
      "type": "timeseries",
      "id": 6,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "node_load1{instance=~\"$instance:9100\"}",
          "legendFormat": "Load 1m",
          "refId": "A"
        },
        {
          "expr": "node_load5{instance=~\"$instance:9100\"}",
          "legendFormat": "Load 5m",
          "refId": "B"
        },
        {
          "expr": "node_load15{instance=~\"$instance:9100\"}",
          "legendFormat": "Load 15m",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          }
        }
      }
    },
    {
      "title": "Host Memory Utilization Detail",
      "type": "timeseries",
      "id": 7,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{instance=~\"$instance:9100\"}",
          "legendFormat": "Total RAM",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemAvailable_bytes{instance=~\"$instance:9100\"}",
          "legendFormat": "Available RAM",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5
          },
          "unit": "bytes"
        }
      }
    },
    {
      "title": "Host Disk I/O Activity",
      "type": "timeseries",
      "id": 8,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(node_disk_read_bytes_total{instance=~\"$instance:9100\"}[1m]))",
          "legendFormat": "Disk Reads",
          "refId": "A"
        },
        {
          "expr": "sum(rate(node_disk_written_bytes_total{instance=~\"$instance:9100\"}[1m]))",
          "legendFormat": "Disk Writes",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "Bps"
        }
      }
    },
    {
      "title": "Host Network Bandwidth (Rx/Tx)",
      "type": "timeseries",
      "id": 9,
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_bytes_total{instance=~\"$instance:9100\", device=~\"eth0|enp.*\"}[1m])) by (device)",
          "legendFormat": "Rx ({{device}})",
          "refId": "A"
        },
        {
          "expr": "sum(rate(node_network_transmit_bytes_total{instance=~\"$instance:9100\", device=~\"eth0|enp.*\"}[1m])) by (device)",
          "legendFormat": "Tx ({{device}})",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "Bps"
        }
      }
    }
  ],
