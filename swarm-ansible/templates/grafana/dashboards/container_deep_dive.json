  "panels": [
    {
      "title": "Container CPU Usage",
      "type": "gauge",
      "id": 1,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{name=\"$container\", instance=\"$instance\"}[1m])) * 100",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      }
    },
    {
      "title": "Container Memory Usage",
      "type": "stat",
      "id": 2,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(container_memory_usage_bytes{name=\"$container\", instance=\"$instance\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 500000000
              },
              {
                "color": "red",
                "value": 1000000000
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value"
      }
    },
    {
      "title": "Disk I/O IOPS (Read/Write)",
      "type": "stat",
      "id": 3,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(container_fs_reads_bytes_total{name=\"$container\", instance=\"$instance\"}[1m])) + sum(rate(container_fs_writes_bytes_total{name=\"$container\", instance=\"$instance\"}[1m]))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          },
          "unit": "Bps"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value"
      }
    },
    {
      "title": "Network Bandwidth Usage",
      "type": "stat",
      "id": 4,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{name=\"$container\", instance=\"$instance\"}[1m])) + sum(rate(container_network_transmit_bytes_total{name=\"$container\", instance=\"$instance\"}[1m]))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "light-blue"
          },
          "unit": "Bps"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value"
      }
    },
    {
      "title": "CPU Usage Over Time",
      "type": "timeseries",
      "id": 5,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{name=\"$container\", instance=\"$instance\"}[1m])) * 100",
          "legendFormat": "CPU Usage",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          },
          "unit": "percent"
        }
      }
    },
    {
      "title": "Memory Usage Over Time",
      "type": "timeseries",
      "id": 6,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(container_memory_usage_bytes{name=\"$container\", instance=\"$instance\"})",
          "legendFormat": "Memory Total",
          "refId": "A"
        },
        {
          "expr": "sum(container_memory_cache{name=\"$container\", instance=\"$instance\"})",
          "legendFormat": "Memory Cache",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "bytes"
        }
      }
    },
    {
      "title": "Network Traffic (Rx/Tx)",
      "type": "timeseries",
      "id": 7,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{name=\"$container\", instance=\"$instance\"}[1m]))",
          "legendFormat": "Received (Rx)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{name=\"$container\", instance=\"$instance\"}[1m]))",
          "legendFormat": "Transmitted (Tx)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "Bps"
        }
      }
    },
    {
      "title": "Disk I/O Activity",
      "type": "timeseries",
      "id": 8,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(container_fs_reads_bytes_total{name=\"$container\", instance=\"$instance\"}[1m]))",
          "legendFormat": "Reads",
          "refId": "A"
        },
        {
          "expr": "sum(rate(container_fs_writes_bytes_total{name=\"$container\", instance=\"$instance\"}[1m]))",
          "legendFormat": "Writes",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "Bps"
        }
      }
    }
  ],
